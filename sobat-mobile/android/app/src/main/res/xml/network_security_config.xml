<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default configuration: allow all trusted CAs -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Specific config for production API -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.sobat-hr.com</domain>
        <domain includeSubdomains="true">sobat-hr.com</domain>
    </domain-config>
</network-security-config>
