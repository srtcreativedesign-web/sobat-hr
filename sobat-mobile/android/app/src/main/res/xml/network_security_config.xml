<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default configuration: allow all trusted CAs -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for local development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="true">192.168.1.11</domain>
        <domain includeSubdomains="true">192.168.1.12</domain>
        <domain includeSubdomains="true">192.168.1.27</domain>
        <domain includeSubdomains="true">192.168.0.106</domain>
    </domain-config>

    <!-- Specific config for production API (HTTPS only) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.sobat-hr.com</domain>
        <domain includeSubdomains="true">sobat-hr.com</domain>
    </domain-config>
</network-security-config>
